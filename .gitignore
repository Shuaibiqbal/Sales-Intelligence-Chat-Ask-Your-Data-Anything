# =============================================================================
# Sales Intelligence Chat — .gitignore
# =============================================================================

# =============================================================================
# 🔑 SECRETS & API KEYS — Never commit these
# =============================================================================
.env
.env.*
.env.local
.env.development
.env.production
.env.staging
*.key
*.pem
secrets.toml
.streamlit/secrets.toml

# =============================================================================
# 📦 DATASETS & DATA FILES — Too large / sensitive for Git
# =============================================================================
data/
!data/.gitkeep          # keeps the empty data/ folder tracked

# Individual data file patterns (safety net if stored outside data/)
*.csv
*.tsv
*.gz
*.gzip
*.zip
*.tar
*.tar.gz
*.parquet
*.feather
*.arrow
*.h5
*.hdf5
*.pkl
*.pickle
*.db
*.sqlite
*.sqlite3

# Excel
*.xlsx
*.xls
*.xlsm
*.xlsb

# Output/export files generated by the app
output.csv
output.xlsx
region_sales.csv
top_cities_stockout.csv
exports/
cache/
history.db

# =============================================================================
# 🐍 PYTHON
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
MANIFEST
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.log

# =============================================================================
# 🧪 VIRTUAL ENVIRONMENTS
# =============================================================================
venv/
env/
.venv/
ENV/
env.bak/
venv.bak/

# =============================================================================
# 📓 JUPYTER NOTEBOOKS (checkpoints)
# =============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# =============================================================================
# 🖥️ OS FILES
# =============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# =============================================================================
# 🛠️ IDE & EDITORS
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.spyderproject.cfg
.ropeproject/

# =============================================================================
# ☁️ STREAMLIT
# =============================================================================
.streamlit/secrets.toml
# Keep .streamlit/config.toml if you have theme/server settings to share
# !.streamlit/config.toml

# =============================================================================
# 🤖 AI / ML ARTIFACTS
# =============================================================================
# LangChain / OpenAI cache
.langchain.db
langchain_cache/

# Model weights & embeddings (if added later)
*.bin
*.pt
*.pth
*.safetensors
*.onnx
chroma_db/
faiss_index/
vector_store/
